# Copy to .env.local and fill in. Used by the backend (local dev and Docker).

# ----- Required -----
SESSION_SECRET=your-session-secret-min-32-chars
COOKIE_SECRET=your-cookie-secret

# ----- Optional (Docker compose sets MONGODB_URI, REDIS_URL, CORS_ORIGIN when using Docker) -----
# PORT=2000
# MONGODB_URI=mongodb://localhost:27017/QuizzConnect
# REDIS_URL=redis://localhost:6379
# CORS_ORIGIN=http://localhost:3221

# ----- Email (Brevo) -----
# BREVO_API_KEY=xx
# SENDER_EMAIL=xx
