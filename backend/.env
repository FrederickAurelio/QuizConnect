# Copy to .env.local and fill in. Used by the backend (local dev and Docker).

# ----- Required -----
SESSION_SECRET=your-session-secret-min-32-chars
COOKIE_SECRET=your-cookie-secret

# ----- Email (Brevo) -----
# BREVO_API_KEY=xx
# SENDER_EMAIL=xx

# ----- Openrouter -----
# OPENROUTER_API_KEY=xxx
# OPENROUTER_MODEL="stepfun/step-3.5-flash:free"
# Optional: cheaper model for the "should we do web search?" decider.
# If empty/unset, backend falls back to OPENROUTER_MODEL.
# OPENROUTER_WEB_DECIDER_MODEL=""
# Optional: if the decider fails to produce valid JSON, choose whether to default to web search.
# Defaults to "false" (cost-optimized). Set to "true" if you prefer correctness over cost.
# OPENROUTER_WEB_DECIDER_FALLBACK_NEED_WEB="false"

# ----- Tavily -----
# TAVILY_API_KEY=xxx

# ----- AI Explain Logs -----


# ----- Optional (Docker compose sets MONGODB_URI, REDIS_URL, CORS_ORIGIN when using Docker) -----
# PORT=2000
# MONGODB_URI=mongodb://localhost:27017/QuizzConnect
# REDIS_URL=redis://localhost:6379
# CORS_ORIGIN=http://localhost:3221
